# ============ LexGraph environment ============

# --- runtime ---
APP_ENV=local
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8080
API_PREFIX=/api

# --- auth ---
AUTH_SECRET_KEY=change-me-to-a-long-random-string-at-least-32-bytes
AUTH_TOKEN_EXPIRES_MIN=60

# --- Graphiti (primary graph engine) ---
# Graphiti uses its own embedder + LLM config; we route both through OpenAI by
# default but the abstraction is in lexgraph.graph.graphiti_client.
GRAPHITI_LLM_PROVIDER=openai          # openai | local
GRAPHITI_EMBED_MODEL=text-embedding-3-small
GRAPHITI_EMBED_DIM=1536

# --- Neo4j (optional, used by Graphiti as persistent store) ---
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me-neo4j
NEO4J_DATABASE=neo4j

# --- Postgres (audit / metadata / jobs) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=lexgraph
POSTGRES_USER=lexgraph
POSTGRES_PASSWORD=change-me-postgres
DATABASE_URL=postgresql+psycopg://lexgraph:change-me-postgres@postgres:5432/lexgraph

# --- Redis (event bus + cache) ---
REDIS_URL=redis://redis:6379/0
EVENT_BUS_BACKEND=redis-streams       # redis-streams | kafka

# --- MinIO / S3 (object store for raw files) ---
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=lexgraph
MINIO_SECRET_KEY=change-me-minio
MINIO_SECURE=false
MINIO_BUCKET_PUBLIC=lexgraph-public
MINIO_BUCKET_PRIVATE=lexgraph-private

# --- Qdrant (optional semantic fallback) ---
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION_PUBLIC=lex_public
QDRANT_COLLECTION_PRIVATE=lex_private

# --- Models ---
# Generator is open-source-first; fall back to OpenAI if OPENAI_API_KEY is set.
OPENAI_API_KEY=
GENERATION_MODEL=gpt-4.1-mini
GENERATION_PROVIDER=openai            # openai | hf | local-ollama
HF_GENERATION_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct

# Semantic fallback / reranker (legal-domain first; fall back to general).
LEGAL_EMBEDDING_MODEL=law-ai/InLegalBERT
GENERAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RERANKER_MODEL=BAAI/bge-reranker-base

# --- Enrichment: legal NER ---
# The EnrichAgent always runs the regex baseline. When ENRICH_NER_ENABLED=true
# AND ENRICH_NER_MODEL is set, a HuggingFace token-classification model is
# layered on top. Candidates:
#   opennyaiorg/en_legal_ner_trf   (OpenNyAI Indian Legal NER — spaCy pipeline;
#                                   needs a custom loader, not auto-loadable)
#   dslim/bert-base-NER            (generic English NER; safe fallback)
#   <your-org>/InLegalBERT-NER     (community fine-tunes of InLegalBERT)
# On first use the model weights are downloaded to the HF cache volume. If
# the load fails (offline / typo / cache miss) the wrapper logs a WARN and
# the pipeline continues with regex-only NER.
ENRICH_NER_ENABLED=false
ENRICH_NER_MODEL=
ENRICH_NER_DEVICE=auto                # auto | cpu | cuda | mps

# --- Retrieval behaviour ---
RETRIEVAL_MODE=graph_plus_semantic    # graph_only | graph_plus_semantic | graph_plus_semantic_plus_rerank
GRAPH_MAX_HOPS=3
GRAPH_MAX_NODES=400
SEMANTIC_FALLBACK_TOPK=20
RERANK_TOPK=10
EVIDENCE_MAX_SPANS=12
EVIDENCE_MAX_TOKENS=3500

# --- OCR ---
OCR_ENABLED=true
OCR_LANGS=eng+hin

# --- Ingestion ---
INGEST_TMP_DIR=/tmp/lexgraph-ingest
INGEST_MAX_FILE_MB=200

# --- Public corpus adapters (toggle on as you wire them) ---
ADAPTER_INDIA_CODE=true
ADAPTER_SUPREME_COURT_OPENDATA=true
ADAPTER_HIGH_COURT=true
ADAPTER_NYAYA_ANUMANA=true
ADAPTER_ILDC=true
ADAPTER_OPENNYAI=true

# --- UI ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api
