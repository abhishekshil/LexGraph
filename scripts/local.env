#!/usr/bin/env bash
# Env overrides when running Python/UI processes on the host while the
# infra (postgres/neo4j/redis/minio/qdrant) runs inside docker compose.
# Source this file: `source scripts/local.env`

export NEO4J_URI=bolt://localhost:7687
export POSTGRES_HOST=localhost
export DATABASE_URL=postgresql+psycopg://lexgraph:change-me-postgres@localhost:5432/lexgraph
export REDIS_URL=redis://localhost:6379/0
export MINIO_ENDPOINT=localhost:9000
export QDRANT_URL=http://localhost:6333
